# Optional AI-provider API keys. These are FALLBACKS used when your Claude Code
# session is unavailable (e.g. it hit its usage limit). You can also set/manage
# them in the app's Settings page — an env var here always overrides a stored key.
#
# You only need keys for the providers you actually want as fallbacks. Leave the
# rest blank. Claude itself needs no key (it uses your local Claude Code session);
# in fact ANTHROPIC_API_KEY should stay UNSET so Claude uses your subscription.

# Google Gemini (multimodal — the whiteboard coach works). https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter — free models like qwen3-coder / deepseek. https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq — very fast Llama 3.3 70B. https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras — high daily volume. https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# Mistral. https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=
